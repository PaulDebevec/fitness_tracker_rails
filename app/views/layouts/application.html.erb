<!DOCTYPE html>
<html>
  <head>
    <title>Fitness Progression App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-body">
    <header class="navbar">
      <div class="navbar-inner">
        <div class="navbar-left">
          <%= link_to "Fitness Progression", root_path, class: "brand-link" %>
          <%= link_to "Profiles", profiles_path, class: "nav-link" %>
          <% if controller_name == "check_ins" || controller_name == "reports" || controller_name == "measurements" %>
            <%= link_to "Back to Profile", profile_path(@profile), class: "nav-link" %>
          <% end %>
        </div>
        <div class="navbar-right">
          <% if logged_in? %>
            <%= link_to "My Profile", profile_path(current_user.profile), class: "nav-link" %>
            <%= button_to "Log Out", logout_path, method: :delete %>
          <% else %>
            <%= link_to "Sign Up", signup_path, class: "nav-link" %>
            <%= link_to "Log In", login_path, class: "nav-link" %>
          <% end %>
        </div>
       </div>
      </div>
    </header>

    <main class="page-shell">
      <% flash.each do |type, message| %>
        <div class="flash <%= type %>">
          <%= message %>
        </div>
      <% end %>

      <div class="page-card">
        <%= yield %>
      </div>
    </main>
  </body>
</html>