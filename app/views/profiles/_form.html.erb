<%= form_with model: profile, class: "stacked-form" do |form| %>

  <% if profile.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(profile.errors.count, "error") %> prevented this profile from being saved:</h2>
      <ul>
        <% profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <%= form.label :display_name %>
    <%= form.text_field :display_name %>
  </div>

  <div class="form-field">
    <%= form.label :unit_system %>
    <%= form.select :unit_system, [["Imperial", "imperial"], ["Metric", "metric"]] %>
  </div>

  <div class="form-field">
    <%= form.label :public_profile, "Profile Visibility" %>

    <div class="checkbox-row">
      <%= form.check_box :public_profile %>
      <span>This profile is visible to others</span>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit profile.persisted? ? "Update Profile" : "Create Profile" %>

    <%= link_to "Cancel",
      request.referer || profile_path(@profile),
      class: "button-secondary" %>
  </div>

<% end %>