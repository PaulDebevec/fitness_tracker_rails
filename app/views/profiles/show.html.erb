<h1><%= @profile.display_name %></h1>

<p>
  <strong>Default unit:</strong>
  <%= @profile.formatted_default_unit %>
</p>

<p>
  <%= link_to "View Progress Report", profile_report_path(@profile), class: "button-link secondary" %>
</p>

<h2>Check-ins</h2>

<% if @check_ins.any? %>
  <div class="check-in-grid">
    <% @check_ins.each do |check_in| %>
      <div class="check-in-card">
        <h3><%= link_to check_in.formatted_date, profile_check_in_path(@profile, check_in) %></h3>
        <p><strong>Notes:</strong> <%= check_in.notes.present? ? truncate(check_in.notes, length: 100) : "No notes added." %></p>
        <p><strong>Measurements:</strong> <%= check_in.measurements.count %></p>

        <div class="card-actions">
          <%= link_to "View", profile_check_in_path(@profile, check_in), class: "button-link secondary" %>
          <%= link_to "Edit", edit_profile_check_in_path(@profile, check_in), class: "button-link" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No check-in history yet.</p>
<% end %>