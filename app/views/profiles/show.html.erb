<h1><%= @profile.display_name %></h1>

<p>
  <strong>Default unit:</strong>
  <%= @profile.formatted_default_unit %>
</p>

<p>
  <%= link_to "View Progress Report", profile_report_path(@profile), class: "button-link secondary" %>
</p>

<h2>Check-ins</h2>

<% if @check_ins.any? %>
  <div class="check-in-grid">
    <% @check_ins.each do |check_in| %>
      <%= link_to profile_check_in_path(@profile, check_in), class: "check-in-card-link" do %>
  <div class="check-in-card">
    <div class="check-in-card-header">
      <h3><%= check_in.formatted_date %></h3>
    </div>

    <div class="check-in-card-body">
      <p>
        <strong>Notes:</strong>
        <%= check_in.notes.present? ? truncate(check_in.notes, length: 100) : "No notes added." %>
      </p>

      <div class="check-in-meta">
        <span><strong>Measurements:</strong> <%= check_in.measurements.count %></span>
        <span><strong>Photos:</strong> <%= [
          check_in.upper_front_photo.attached?,
          check_in.upper_back_photo.attached?,
          check_in.lower_front_photo.attached?,
          check_in.lower_back_photo.attached?
        ].count(true) %></span>
      </div>
    </div>
  </div>
<% end %>
    <% end %>
  </div>
<% else %>
  <p>No check-ins yet.</p>
<% end %>