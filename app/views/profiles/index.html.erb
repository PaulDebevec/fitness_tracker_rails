<h1>Profiles</h1>

<div class="page-actions">
  <div class="page-actions-left"></div>

  <div class="page-actions-right">
    <%= link_to "Create New Profile", new_profile_path, class: "button-link" %>
  </div>
</div>

<% if @profiles.any? %>
  <div class="profile-grid">
    <% @profiles.each do |profile| %>
      <%= link_to profile_path(profile), class: "profile-card-link" do %>
        <div class="profile-card">
          <div class="profile-card-header">
            <h2><%= profile.display_name %></h2>
          </div>

          <div class="profile-card-body">
            <p>
              <strong>Latest Check-in:</strong>
              <%= profile.latest_check_in&.formatted_date || "No check-ins yet" %>
            </p>

            <p>
              <strong>Total Check-ins:</strong>
              <%= profile.check_ins.count %>
            </p>

            <div class="card-hint-row">
              <span class="card-hint-text card-hint-desktop">Details</span>
              <span class="card-hint-text card-hint-mobile">Tap to view details</span>
              <span class="card-hint-arrow">›</span>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="empty-state-card">
    <h2>No profiles yet</h2>
  </div>
<% end %>