<% content_for :title, "#{@profile.display_name} Check-in | BodMetriks" %>
<h1>Check-in for <%= @profile.display_name %></h1>

<div class="page-actions">
  <div class="page-actions-left">
    <%= link_to "Back to Profile",
          profile_path(@profile),
          class: "button-link" %>
  </div>
  <% if can_manage_profile?(@profile) %>
    <div class="page-actions-secondary">
      <div class="page-actions-right">
        <%= link_to "Add Measurement",
            new_profile_check_in_measurement_path(@profile, @check_in),
            class: "button-link subtle" %>

        <%= link_to "Edit Check-in",
                    edit_profile_check_in_path(@profile, @check_in),
                    class: "button-link subtle" %>
      </div>
    </div>
    <% end %>
</div>

<div class="detail-card">
  <div class="detail-grid">
    <div class="detail-section">
      <h2>Check-in Details</h2>

      <p>
        <strong>Date:</strong>
        <%= @check_in.formatted_date %>
      </p>

      <p>
        <strong>Notes:</strong>
        <%= @check_in.notes.present? ? @check_in.notes : "No notes added." %>
      </p>

      <p>
        <strong>Measurements:</strong>
        <%= @measurements.count %>
      </p>

      <p>
        <strong>Progress Photos:</strong>
        <%= [
          @check_in.front_photo.attached?,
          @check_in.back_photo.attached?,
          @check_in.side_photo.attached?
        ].count(true) %>
      </p>
    </div>

    <div class="detail-section">
      <h2>Measurements</h2>

      <% if @measurements.any? %>
        <ul class="measurement-summary-list">
          <% @measurements.each do |measurement| %>
            <li>
              <%= link_to measurement.formatted_body_part,
                  profile_check_in_measurement_path(@profile, @check_in, measurement) %>
              : <%= measurement.value %> <%= @profile.unit_for(measurement.body_part) %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p>No measurements yet.</p>
      <% end %>
    </div>
  </div>

    <% if @check_in.front_photo.attached? ||
          @check_in.back_photo.attached? ||
          @check_in.side_photo.attached? %>

    <% photo_sections = [
      ["Front", "front_photo"],
      ["Back", "back_photo"],
      ["Side", "side_photo"]
    ] %>

    <% attached_photos = photo_sections.select { |_, photo_name| @check_in.public_send(photo_name).attached? } %>

    <% if attached_photos.any? %>
      <div class="photo-grid">
        <% attached_photos.each do |label, photo_name| %>
          <div class="photo-card">
            <p><strong><%= label %></strong></p>
            <div class="photo-card-image-wrapper">
              <%= image_tag @check_in.public_send(photo_name), class: "progress-photo" %>
              <% if can_manage_profile?(@profile) %>
                <%= button_to "×",
                    remove_photo_profile_check_in_path(@profile, @check_in, photo_name: photo_name),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure you want to delete this photo?" },
                    class: "photo-delete-button" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p>No progress photos yet.</p>
    <% end %>

  </div>

<% else %>
  <p>No progress photos yet.</p>
<% end %>

<% if can_manage_profile?(@profile) %>
  <div class="danger-zone photo-empty-state">
    <%= button_to "Delete Check-in",
        profile_check_in_path(@profile, @check_in),
        method: :delete %>
  </div>
<% end %>

</div>

