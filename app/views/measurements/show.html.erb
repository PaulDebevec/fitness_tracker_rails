<h1>Measurement for <%= @check_in.formatted_date %></h1>

<% if can_manage_profile?(@profile) %>
  <div class="page-actions">
      <div class="page-actions-left">
        <%= link_to "Back to Check-in",
          profile_check_in_path(@profile, @check_in),
          class: "button-link" %>
      </div>
      <div class="page-actions-right">
        <div class="page-actions-secondary">
          <%= link_to "Edit Measurement",
              edit_profile_check_in_measurement_path(@profile, @check_in, @measurement),
              class: "button-link subtle" %>
        </div>
    </div>
  </div>
<% end %>


<div class="detail-card">
  <div class="detail-grid">
    <div class="detail-section">
      <h2>Measurement Details</h2>

      <p>
        <strong>Body Part:</strong>
        <%= @measurement.formatted_body_part %>
      </p>

      <p>
        <strong>Value:</strong>
        <%= @measurement.value %> <%= @profile.unit_for(@measurement.body_part) %>
      </p>
    </div>

    <div class="detail-section">
      <h2>Body Part Photo</h2>

      <% if @measurement.body_part_photo.attached? %>
        <div class="photo-card measurement-photo-card">
          <%= image_tag @measurement.body_part_photo, class: "progress-photo" %>
        </div>
      <% else %>
        <p>No photo yet.</p>
      <% end %>
    </div>
  </div>
</div>

<% if can_manage_profile?(@profile) %>
  <div class="danger-zone">
    <%= button_to "Delete Measurement",
        profile_check_in_measurement_path(@profile, @check_in, @measurement),
        method: :delete %>
  </div>
<% end %>
