<h1>Measurements for <%= @check_in.formatted_date %></h1>

<p>
  <%= link_to "Back to Check-in", profile_check_in_path(@profile, @check_in), class: "button-link secondary" %> |
  <%= link_to "New Measurement", new_profile_check_in_measurement_path(@profile, @check_in), class: "button-link secondary" %>
</p>

<% if @measurements.any? %>
  <ul>
    <% @measurements.each do |measurement| %>
      <li>
        <%= link_to measurement.formatted_body_part, profile_check_in_measurement_path(@profile, @check_in, measurement) %> -
        <%= measurement.value %> <%= @profile.abbreviated_default_unit %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No measurements yet.</p>
<% end %>