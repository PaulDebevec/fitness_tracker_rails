<% content_for :title, "Progress Report | #{@profile.display_name} | #{app_name}" %>
<div class="report-header-card">
  <div class="report-header-top">
    <div>
      <h1><%= @profile.display_name %> Progress Report</h1>
      <p class="report-subtitle">
        Review measurement progress over time by body part and timeframe.
      </p>
    </div>

    <div class="report-header-actions">
     <%= link_to "Export CSV",
      profile_report_path(
        @profile,
        format: :csv,
        body_part: @body_part,
        timeframe: @timeframe,
        change_mode: @change_mode
      ),
    class: "button-link secondary" %>
    </div>
  </div>
  <p class="report-filter-label">Filters</p>
  <%= form_with url: profile_report_path(@profile), method: :get, local: true, class: "report-filter-form" do |form| %>
    <div class="report-filter-group">
      <div class="report-filter-field">
        <%= form.label :body_part, "Body Part" %>
        <%= form.select :body_part,
            options_for_select(
              [["All Body Parts", ""]] + Measurement::BODY_PARTS.map { |body_part| [body_part.humanize, body_part] },
              @body_part
            ),
            {},
            { onchange: "this.form.requestSubmit()" } %>
      </div>

      <div class="report-filter-field">
        <%= form.label :timeframe, "Timeframe" %>
        <%= form.select :timeframe,
            options_for_select(
              MeasurementReport::TIMEFRAME_OPTIONS.keys.map { |option| [option.humanize, option] },
              @timeframe
            ),
            {},
            { onchange: "this.form.requestSubmit()" } %>
      </div>
    </div>
  <% end %>
</div>

  <%= turbo_frame_tag "report_charts" do %>
  <% if @report.measurements.any? %>
    <% if @body_part.present? %>
      <div class="chart-card">
        <h2><%= @body_part.humanize %> Progress Chart</h2>

        <div class="chart-wrapper">
         <%= line_chart @report.chart.chart_data,
            height: "340px",
            xtitle: "Check-in Date",
            ytitle: "#{@body_part.humanize} (#{@profile.unit_for(@body_part)})",
            min: @report.chart.min_chart_value,
            max: @report.chart.max_chart_value,
            colors: [@report.chart.selected_body_part_color],
            points: true,
            curve: false,
            legend: false,
            thousands: ",",
            dataset: { spanGaps: true },
            library: chart_theme_options.deep_merge({
              animation: {
                duration: 700,
                easing: "easeOutQuart"
              }
            }) %>
        </div>
      </div>
    <% else %>
      <div class="top-chart-card">
        <div class="chart-card-header">
          <h2>Bodily Changes (<%= @report.chart.formatted_change_mode %>)</h2>

          <div class="chart-toggle-group">
            <%= link_to "Since Previous Check-in",
                profile_report_path(
                  @profile,
                  body_part: @body_part,
                  timeframe: @timeframe,
                  change_mode: "previous"
                ),
                class: "chart-toggle-button #{'active' if @change_mode == 'previous'}",
                data: { turbo_frame: "report_charts" } %>

            <%= link_to "Since First Check-in",
                profile_report_path(
                  @profile,
                  body_part: @body_part,
                  timeframe: @timeframe,
                  change_mode: "starting"
                ),
                class: "chart-toggle-button #{'active' if @change_mode == 'starting'}",
                data: { turbo_frame: "report_charts" } %>
          </div>
        </div>

        <div class="chart-wrapper">
          <%= line_chart @report.chart.body_measurement_change_chart_data,
              height: "340px",
              xtitle: "Check-in Date",
              ytitle: "Change",
              min: @report.chart.min_body_measurement_change_chart_value,
              max: @report.chart.max_body_measurement_change_chart_value,
              points: true,
              curve: false,
              legend: "bottom",
              thousands: ",",
              dataset: { spanGaps: true },
              library: chart_theme_options.deep_merge({
                animation: {
                  duration: 700,
                  easing: "easeOutQuart"
                }
              }) %>
        </div>
      </div>

      <div class="chart-grid">
        <% if @report.chart.weight_measurements_present? %>
          <div class="chart-card">
            <h2>Weight Progress</h2>

            <div class="chart-wrapper">
              <%= line_chart @report.chart.weight_chart_data,
                  height: "300px",
                  xtitle: "Check-in Date",
                  ytitle: "Weight (#{@profile.unit_for('weight')})",
                  min: @report.chart.min_weight_chart_value,
                  max: @report.chart.max_weight_chart_value,
                  points: true,
                  curve: false,
                  legend: false,
                  thousands: ",",
                  dataset: { spanGaps: true },
                  library: chart_theme_options.deep_merge({
                    animation: {
                      duration: 700,
                      easing: "easeOutQuart"
                    }
                  }) %>
            </div>
          </div>
        <% end %>

        <% if @report.chart.body_measurements_present? %>
          <div class="chart-card">
            <h2>Body Measurements Progress</h2>

            <div class="chart-wrapper">
              <%= line_chart @report.chart.body_measurement_chart_data,
                  height: "340px",
                  xtitle: "Check-in Date",
                  ytitle: "Measurement",
                  min: @report.chart.min_body_measurement_chart_value,
                  max: @report.chart.max_body_measurement_chart_value,
                  points: true,
                  curve: false,
                  legend: "bottom",
                  thousands: ",",
                  dataset: { spanGaps: true },
                  library: chart_theme_options.deep_merge({
                    animation: {
                      duration: 700,
                      easing: "easeOutQuart"
                    }
                  }) %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
<hr>

<% if @body_part.present? %>
  <% summary = @report.summary %>

  <% if summary[:count] > 0 %>
    <div class="report-grid">
      <div class="report-card">
        <h2><%= summary[:body_part].humanize %></h2>

        <div class="report-card-body">
          <div class="report-summary">
            <p><strong>Timeframe:</strong> <%= summary[:timeframe].humanize %></p>
            <p><strong>Entries:</strong> <%= summary[:count] %></p>
            <p><strong>Start Date:</strong> <%= summary[:start_date] %></p>
            <p><strong>End Date:</strong> <%= summary[:end_date] %></p>
            <p><strong>Starting Value:</strong> <%= summary[:starting_value] %></p>
            <p><strong>Ending Value:</strong> <%= summary[:ending_value] %></p>
            <p><strong>Change:</strong> <%= summary[:change] %></p>
            <p><strong>Minimum:</strong> <%= summary[:min] %></p>
            <p><strong>Maximum:</strong> <%= summary[:max] %></p>
            <p><strong>Average:</strong> <%= summary[:average] %></p>
          </div>

          <div class="report-history">
            <strong>History</strong>
            <ul>
              <% @report.measurements.each do |measurement| %>
                <li>
                  <%= link_to measurement.check_in.formatted_date,
                      profile_check_in_path(@profile, measurement.check_in) %>
                  : <%= measurement.value %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <p>No measurements found for this body part.</p>
  <% end %>
<% else %>
    <% grouped_summary = @report.summary %>

    <% if grouped_summary.any? %>
        <div class="report-grid">

        <% Measurement::BODY_PARTS.each do |body_part| %>
            <% summary = grouped_summary[body_part] %>
            <% next unless summary %>

            <div class="report-card">
                <h2><%= body_part.humanize %></h2>

                <div class="report-card-body">

                    <div class="report-summary">
                        <p><strong>Entries:</strong> <%= summary[:count] %></p>
                        <p><strong>Start Date:</strong> <%= summary[:start_date] %></p>
                        <p><strong>End Date:</strong> <%= summary[:end_date] %></p>
                        <p><strong>Start:</strong> <%= summary[:starting_value] %></p>
                        <p><strong>End:</strong> <%= summary[:ending_value] %></p>
                        <p><strong>Change:</strong> <%= summary[:change] %></p>
                        <p><strong>Min:</strong> <%= summary[:min] %></p>
                        <p><strong>Max:</strong> <%= summary[:max] %></p>
                        <p><strong>Average:</strong> <%= summary[:average] %></p>
                    </div>

                    <div class="report-history">
                        <strong>History</strong>
                        <ul>
                            <% @report.measurements_grouped_by_body_part[body_part].each do |measurement| %>
                            <li>
                                <%= link_to measurement.check_in.formatted_date,
                                profile_check_in_path(@profile, measurement.check_in) %>
                                : <%= measurement.value %>
                            </li>
                            <% end %>
                        </ul>
                    </div>

                </div>
            </div>

        <% end %>

        </div>
    <% else %>
        <p>No measurements found for this timeframe.</p>
    <% end %>
<% end %>