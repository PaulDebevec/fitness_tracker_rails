<h1>Forgot Password</h1>

<div class="form-card">
  <%= form_with url: password_resets_path, method: :post, class: "stacked-form" do %>
    <div class="form-field">
      <%= label_tag :email, "Email" %>
      <%= email_field_tag :email, params[:email] %>
    </div>

    <div class="form-actions">
      <%= submit_tag "Send Reset Instructions" %>
    </div>
  <% end %>
</div>